<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Listing App</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="nav-container">
            <a href="/" class="nav-brand">
                📋 Listing App
            </a>
            <div class="nav-links">
                <a href="/" class="nav-link <%= title === 'All Listings' ? 'active' : '' %>">
                    All Listings
                </a>
                <a href="/listings/new" class="nav-link btn-primary">
                    + Add New Listing
                </a>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="container">
        <!-- Page Header -->
        <div class="page-header">
            <h1 class="page-title">
                <%= typeof searchTerm !== 'undefined' ? 'Search Results' : 'All Listings' %>
            </h1>
            <p class="page-subtitle">
                <% if (typeof searchTerm !== 'undefined') { %>
                    Showing results for "<strong><%= searchTerm %></strong>" - <%= count %> listing(s) found
                <% } else { %>
                    <%= count %> listing(s) available
                <% } %>
            </p>
        </div>

        <!-- Search Form -->
        <div class="search-container">
            <form action="/search" method="GET" class="search-form">
                <input 
                    type="text" 
                    name="q" 
                    placeholder="Search by title, location, or description..."
                    class="search-input"
                    value="<%= typeof searchTerm !== 'undefined' ? searchTerm : '' %>"
                >
                <button type="submit" class="search-btn">
                    🔍 Search
                </button>
            </form>
        </div>

        <!-- Alert Messages -->
        <% if (message) { %>
            <div class="alert alert-success">
                ✅ <%= message %>
            </div>
        <% } %>

        <% if (error) { %>
            <div class="alert alert-error">
                ❌ <%= error %>
            </div>
        <% } %>

        <!-- Listings Grid -->
        <% if (listings.length > 0) { %>
            <div class="listings-grid">
                <% listings.forEach(function(listing) { %>
                    <div class="listing-card">
                        <div class="card-header">
                            <h3 class="card-title">
                                <a href="/listings/<%= listing.id %>">
                                    <%= listing.title %>
                                </a>
                            </h3>
                            <span class="card-price">
                                $<%= Number(listing.price).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 2}) %>
                            </span>
                        </div>
                        
                        <div class="card-body">
                            <p class="card-description">
                                <%= listing.description.length > 100 ? 
                                    listing.description.substring(0, 100) + '...' : 
                                    listing.description %>
                            </p>
                            <p class="card-location">
                                📍 <%= listing.location %>
                            </p>
                        </div>
                        
                        <div class="card-footer">
                            <small class="card-date">
                                Created: <%= new Date(listing.created_at).toLocaleDateString('en-US', {
                                    year: 'numeric',
                                    month: 'short',
                                    day: 'numeric'
                                }) %>
                            </small>
                            <div class="card-actions">
                                <a href="/listings/<%= listing.id %>" class="btn btn-sm btn-view">
                                    View
                                </a>
                                <a href="/listings/<%= listing.id %>/edit" class="btn btn-sm btn-edit">
                                    Edit
                                </a>
                                <form action="/listings/<%= listing.id %>?_method=DELETE" 
                                      method="POST" 
                                      class="inline-form"
                                      onsubmit="return confirm('Are you sure you want to delete this listing?');">
                                    <button type="submit" class="btn btn-sm btn-delete">
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                <% }); %>
            </div>
        <% } else { %>
            <!-- Empty State -->
            <div class="empty-state">
                <div class="empty-icon">📭</div>
                <h2>No Listings Found</h2>
                <% if (typeof searchTerm !== 'undefined') { %>
                    <p>No listings match your search for "<%= searchTerm %>"</p>
                    <a href="/" class="btn btn-primary">View All Listings</a>
                <% } else { %>
                    <p>Get started by creating your first listing!</p>
                    <a href="/listings/new" class="btn btn-primary">Create Your First Listing</a>
                <% } %>
            </div>
        <% } %>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <p>&copy; <%= new Date().getFullYear() %> Listing App. Built with Node.js, Express, MySQL & EJS</p>
        </div>
    </footer>
</body>
</html>
